# Test Terraform Variables
# These variables can be used for testing the terraform configuration locally

# Project Configuration
project_name = "sedaro-nano"
environment  = "demo"
aws_region   = "us-east-1"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# Node Configuration - Cost optimized for demo
node_instance_types = ["t3.small"]
node_desired_size   = 1
node_max_size       = 2
node_min_size       = 1

# Addon Configuration
enable_metrics_server     = true
enable_cluster_autoscaler = false

# Access Configuration (test values - replace with real ARNs)
github_actions_role_arn = "arn:aws:iam::123456789012:role/test-github-actions-role"
admin_user_arn          = "arn:aws:iam::123456789012:user/test-admin"
